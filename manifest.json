{
  "manifest_version": 3,
  "name": "Scribe",
  "version": "2.1.0",
  "description": "AI-powered live transcription, screen capture analysis, and real-time Q&A — right in your browser sidepanel.",
  "background": {
    "service_worker": "background-enhanced.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "tabCapture",
    "contextMenus",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.vercel.app/*"
  ],
  "icons": {
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Open Scribe"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content-script.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icon.png",
        "sidepanel.html",
        "sidepanel.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}