{
  "manifest_version": 3,
  "name": "Scribe",
  "version": "2.2.0",
  "description": "AI-powered live transcription, screen capture analysis, and real-time Q&A — right in your browser sidepanel.",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "tabCapture",
    "contextMenus",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.vercel.app/*"
  ],
  "icons": {
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_icon": "icons/icon-128.png",
    "default_title": "Open Scribe"
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/icon-128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}